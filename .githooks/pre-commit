#!/usr/bin/env bash
# Pre-commit hook – auto-fix lint issues and format staged Python files.
# Installed via: just install-hooks

set -e

# Collect staged .py files (only those that still exist on disk).
STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=d -- '*.py')

if [ -z "$STAGED_PY_FILES" ]; then
    exit 0
fi

# Run ruff fix & format on the whole src/ tree (fast, and avoids partial-file issues).
# Inline uv commands rather than calling `just fix` — git hook env may not have just in PATH.
uv run ruff check --fix src/
uv run ruff format src/

# Re-stage any files that were modified by the formatter.
echo "$STAGED_PY_FILES" | xargs git add

exit 0
